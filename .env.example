PORT=3001
CORS_ORIGINS=http://localhost:5173,http://localhost:5174
NODE_ENV=development
ENFORCE_HTTPS=false
ENABLE_PUBLIC_UPLOADS=false
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=120

# MongoDB
# Keep MongoDB Atlas connections on mongodb+srv://.
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.example.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=menteamiga

# Temporary local-development workaround when Node DNS uses 127.0.0.1
# and MongoDB SRV lookup fails with ECONNREFUSED.
# MONGODB_DNS_SERVERS=1.1.1.1,8.8.8.8

# Auth
JWT_SECRET=change-me-to-a-long-random-secret-with-32-plus-chars
JWT_EXPIRES_IN=7d

# IA y RAG
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-3.5-turbo
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# Atlas Vector Search index name on documentchunks.embedding.
MONGODB_ATLAS_VECTOR_INDEX=

# Limits
FREE_DAILY_LIMIT=20
FREE_MONTHLY_LIMIT=500
PREMIUM_DAILY_LIMIT=500
PREMIUM_MONTHLY_LIMIT=10000

# Background processing
REDIS_URL=

# Storage
STORAGE_PROVIDER=local
BLOB_READ_WRITE_TOKEN=
# Optional comma-separated allowlist for remote storage downloads.
STORAGE_ALLOWED_REMOTE_HOST=

# Notifications for account security codes
# Local development may keep providers as none; the API returns devCode only when the selected channel has provider=none.
# Production requires EMAIL_PROVIDER=resend and SMS_PROVIDER=twilio.
EMAIL_PROVIDER=none
RESEND_API_KEY=
EMAIL_FROM=
SMS_PROVIDER=none
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Twilio numbers must use E.164 format, for example +573001112233.
TWILIO_FROM_NUMBER=
